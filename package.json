{
  "name": "tokentrack",
  "displayName": "TokenTrack",
  "description": "See Cursor Premium Auto and API token usage as live progress bars in the status bar.",
  "version": "0.1.1",
  "publisher": "kennycruzado",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1A1D21",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kennycruzado/tokentrack.git"
  },
  "bugs": {
    "url": "https://github.com/kennycruzado/tokentrack/issues"
  },
  "homepage": "https://github.com/kennycruzado/tokentrack#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cursor",
    "tokens",
    "usage",
    "billing",
    "status bar",
    "premium"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokentrack.refresh",
        "title": "TokenTrack: Refresh Usage"
      },
      {
        "command": "tokentrack.openDashboard",
        "title": "TokenTrack: Open Usage Dashboard"
      }
    ],
    "configuration": {
      "title": "TokenTrack",
      "properties": {
        "tokentrack.pollIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 600,
          "description": "How often to refresh usage from Cursor (seconds)."
        },
        "tokentrack.barWidth": {
          "type": "number",
          "default": 8,
          "minimum": 4,
          "maximum": 20,
          "description": "Width of each ASCII progress bar in characters."
        },
        "tokentrack.showAuto": {
          "type": "boolean",
          "default": true,
          "description": "Show the Auto (green) usage bar in the status bar."
        },
        "tokentrack.showApi": {
          "type": "boolean",
          "default": true,
          "description": "Show the API (orange) usage bar in the status bar."
        }
      }
    },
    "colors": [
      {
        "id": "tokentrack.auto",
        "description": "Color for the Auto usage status bar item",
        "defaults": {
          "dark": "#3DDC97",
          "light": "#0A7A4B",
          "highContrast": "#3DDC97"
        }
      },
      {
        "id": "tokentrack.api",
        "description": "Color for the API usage status bar item",
        "defaults": {
          "dark": "#F5A623",
          "light": "#C46A00",
          "highContrast": "#F5A623"
        }
      },
      {
        "id": "tokentrack.total",
        "description": "Color for the Total fallback usage status bar item",
        "defaults": {
          "dark": "#9AA0A6",
          "light": "#5F6368",
          "highContrast": "#FFFFFF"
        }
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run compile && vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
